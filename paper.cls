% ========== 标题层级与页眉标记 ==========
% 保持两层目录：section 与 subsection
\setcounter{secnumdepth}{2}
\setcounter{tocdepth}{2}

\renewcommand{\sectionmark}[1]{\markboth{#1}{}}
\renewcommand{\subsectionmark}[1]{\markright{#1}}

% subsection 在正文显示为美化标题，同时用于页眉右侧标记
\titleformat{\subsection}[block]
  {\large\bfseries\sffamily\color{blue!75!black}}
  {\thesubsection}
  {0.6em}
  {}
  [\vspace{-1em}\color{blue!45!black}\rule{0.33\textwidth}{0.5pt}]
\titlespacing*{\subsection}{0pt}{1.1em}{0.7em}
\newif\ifpaper@seenfirstsubsection
\paper@seenfirstsubsectionfalse
\pretocmd{\subsection}{%
  \ifpaper@seenfirstsubsection
    \clearpage
  \else
    \global\paper@seenfirstsubsectiontrue
  \fi
}{}{}

