% Page layout
\geometry{top=1in,bottom=1in,left=0.5in,right=0.5in}
\setlength{\columnsep}{0.5in}

% Header and footer
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\textbf{Physical Cheatsheet}}
\fancyhead[R]{\thepage}
\fancyfoot[C]{\textit{Generated by Linghui Ding}}

% Section formatting
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\small\bfseries}{\thesubsubsection}{1em}{}

% Multicolumn environment
\setlength{\columnseprule}{0.4pt}
\definecolor{columnrulecolor}{gray}{0.8}
\setlength{\columnsep}{1em}

% Custom commands
\newcommand{\important}[2]{#1\ :\ \textcolor{red}{\textbf{#2}}}
\newcommand{\code}[1]{\texttt{#1}}

% Begin document in two-column mode
\AtBeginDocument{
    \begin{multicols*}{2}
}

% End document in two-column mode
\AtEndDocument{
    \end{multicols*}
}

\newtcolorbox{noticebox}[1][]{
  colback=orange!20,        % 内容区背景
  colframe=red!80!black,    % 边框
  boxrule=1pt,
  sharp corners,
  enhanced,
  before skip=10pt, after skip=10pt,
  title={\strut\textcolor{white}{\bfseries 注意}},
  fonttitle=\bfseries,
  coltitle=white,
  attach boxed title to top left={yshift=-2mm, xshift=2mm},
  boxed title style={
    enhanced,
    size=small,
    colframe=red!80!black,
    top=0mm,
    bottom=0mm,
    left=6mm,
    right=6mm,
    arc=1mm,
    boxrule=0pt,
    interior style={
      left color=red!80!black,
      right color=yellow!80!orange,
      middle color=orange!80!yellow
    }
  },
  #1
}

\newcommand{\notice}[1]{%
    \begin{noticebox}
        #1
    \end{noticebox}
}

\newtcolorbox{hintbox}[1][]{
  colback=blue!10,        % 内容区背景
  colframe=blue!80!black, % 边框
  boxrule=1pt,
  sharp corners,
  enhanced,
  before skip=10pt, after skip=10pt,
  title={\strut\textcolor{white}{\bfseries 你知道吗？}},
  fonttitle=\bfseries,
  coltitle=white,
  attach boxed title to top left={yshift=-2mm, xshift=2mm},
  boxed title style={
    enhanced,
    size=small,
    colframe=blue!80!black,
    top=0mm,
    bottom=0mm,
    left=6mm,
    right=6mm,
    arc=1mm,
    boxrule=0pt,
    interior style={
      left color=blue!80!black,
      right color=cyan!80!blue,
      middle color=cyan!80!blue
    }
  },
  #1
}

\newcommand{\hint}[1]{%
    \begin{hintbox}
        #1
    \end{hintbox}
}