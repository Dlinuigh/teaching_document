\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{cheatsheet}[2023/10/01 Cheatsheet class]
% Set default font size and line spacing
\newcommand{\cheatsheetfontsize}{10pt}
\LoadClass[\cheatsheetfontsize]{article}

% Load required packages
\RequirePackage[T1]{fontenc}
\RequirePackage[a4paper,margin=1in]{geometry}
\RequirePackage{amsmath}
\RequirePackage{colortbl}
\RequirePackage{chemfig}
\RequirePackage{mhchem}
\RequirePackage{fancyhdr}
\RequirePackage{graphicx}
\RequirePackage{hhline}
\RequirePackage{lastpage}
\RequirePackage{multicol}
\RequirePackage{parskip}
\RequirePackage{seqsplit}
\RequirePackage{setspace}
\RequirePackage{tabularx}
\RequirePackage{tabulary}
\RequirePackage{titlesec}
\RequirePackage[table]{xcolor}
\RequirePackage{xeCJK}


\setmainfont{Liberation Serif}
\setsansfont{Liberation Sans}
\setmonofont{Source Code Pro}
\setCJKmainfont{FandolSong}
\setCJKsansfont{FandolHei}
\setCJKmonofont{Source Code Pro}
\newCJKfontfamily[song]\songfont{FandolSong}
\newCJKfontfamily[hei]\heifont{FandolHei}
\newCJKfontfamily[kai]\kaifont{FandolKai}
\newCJKfontfamily[fs]\fsfont{FandolFang}

% Page layout
\geometry{top=1in,bottom=1in,left=0.5in,right=0.5in}
\setlength{\columnsep}{0.5in}

% Header and footer
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\textbf{Physical Cheatsheet}}
\fancyhead[R]{\thepage}
\fancyfoot[C]{\textit{Generated by Linghui Ding}}

% Section formatting
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\small\bfseries}{\thesubsubsection}{1em}{}

% Multicolumn environment
\setlength{\columnseprule}{0.4pt}
\definecolor{columnrulecolor}{gray}{0.8}
\setlength{\columnsep}{1em}

% Custom commands
\newcommand{\important}[2]{#1\ :\ \textcolor{red}{\textbf{#2}}}
\newcommand{\code}[1]{\texttt{#1}}

% Begin document in two-column mode
\AtBeginDocument{
    \begin{multicols*}{2}
}

% End document in two-column mode
\AtEndDocument{
    \end{multicols*}
}